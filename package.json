{
  "name": "memorygame",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "reset": "react-native start --reset-cache",
    "android": "react-native run-android --active-arch-only --terminal powershell",
    "ios": "react-native run-ios --terminal powershell",
    "both": "react-native run-android && react-native run-ios --mode Debug",
    "lint": "eslint .",
    "android:apk": "ENVFILE=.env.prod cd android && ./gradlew assembleRelease",
    "android:aab": "ENVFILE=.env.prod cd android && ./gradlew bundleRelease",
    "debug": "cd android && ./gradlew assembleDebug",
    "clean": "cd android && ./gradlew clean",
    "syncGradle": "cd android && ./gradlew build"
  },
  "dependencies": {
    "react": "19.0.0",
    "react-native": "0.79.2",
    "react-native-bootsplash": "^7.1.0",
    "react-native-flip-card": "^3.5.7",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-svg": "^15.15.3",
    "styled-components": "^6.3.11"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "18.0.0",
    "@react-native-community/cli-platform-android": "18.0.0",
    "@react-native-community/cli-platform-ios": "18.0.0",
    "@react-native/babel-preset": "0.79.2",
    "@react-native/eslint-config": "0.79.2",
    "@react-native/metro-config": "0.79.2",
    "@react-native/typescript-config": "0.79.2",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.0.0",
    "@types/react-test-renderer": "^19.0.0",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "react-native-svg-transformer": "^1.5.3",
    "react-test-renderer": "19.0.0",
    "typescript": "5.0.4"
  },
  "engines": {
    "node": ">=18"
  }
}
